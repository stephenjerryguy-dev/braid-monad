{
  "name": "braid-monad",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "vercel-build": "next build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "pnpm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat run scripts/test-contracts.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@pythnetwork/entropy-sdk-solidity": "^2.2.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@nomicfoundation/hardhat-ethers": "^4.0.14",
    "@tailwindcss/postcss": "4.2.1",
    "@types/chai": "^5.2.3",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "chai": "^6.2.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "ethers": "^6.17.0",
    "hardhat": "^3.9.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
